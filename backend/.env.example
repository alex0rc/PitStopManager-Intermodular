APP_NAME=PitStopManager
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

FRONTEND_URL=http://localhost:4200

APP_LOCALE=es
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=es_ES

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=pitstop_manager
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=cookie
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=localhost

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
# sync = emails send immediately; database = requires `php artisan queue:work`
QUEUE_CONNECTION=sync

CACHE_STORE=database

SANCTUM_STATEFUL_DOMAINS=localhost:4200,localhost:8000

STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

OPENWEATHERMAP_API_KEY=

# Mail — Mailtrap Email Testing (sandbox): https://mailtrap.io → Email Testing → Inboxes → SMTP
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="noreply@pitstopmanager.com"
MAIL_FROM_NAME="${APP_NAME}"
